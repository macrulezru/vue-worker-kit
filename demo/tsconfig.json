{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "ES2022.Error", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "paths": {
      "vue-worker-kit/worker": ["../src/worker/defineWorkerHandler.ts"],
      "vue-worker-kit/pool": ["../src/adapters/pool.ts"],
      "vue-worker-kit/computed": ["../src/adapters/computed.ts"],
      "vue-worker-kit/devtools": ["../src/devtools/index.ts"],
      "vue-worker-kit": ["../src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "env.d.ts", "../src/worker/global.d.ts"]
}
